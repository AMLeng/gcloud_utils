export PROJECT="my-gcp-project-id"
export SERVICE_ACCOUNT="123456789-compute@developer.gserviceaccount.com"
export REMOTE_USER="myuser"
export TARGET_REPO="https://github.com/user/repo.git"
export UV_EXTRAS="tpu cuda"

# Optional extra Claude Code plugins to install on remote nodes (in addition
# to the always-installed `superpowers`). Newline-separated entries; each
# entry is "<marketplace-source> <plugin@marketplace>". Example:
# export ADDITIONAL_CLAUDE_PLUGINS="EveryInc/compound-engineering-plugin compound-engineering@compound-engineering-plugin"
export ADDITIONAL_CLAUDE_PLUGINS=""

export CPU_ZONE="us-central1-a"
export CPU_REGION="us-central1"
export CPU_NAME="my-cpu"
export CPU_MACHINE_TYPE="c4-standard-8"

export TPU_ZONE="us-west4-a"
export TPU_REGION="us-west4"
export TPU_NAME="my-tpu"
export TPU_QUEUE_NAME="my-tpu-queue-request"
export TPU_ACCELERATOR_TYPE="v5litepod-4"
export TPU_RUNTIME_VERSION="v2-alpha-tpuv5-lite"
export NUM_WORKERS=1
